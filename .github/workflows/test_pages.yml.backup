name: Deploy Jekyll site tnt to Pages

on:
  push:
    branches: 
      - "master"
    paths:
      - "docs/**"
  workflow_dispatch:

permissions:
  contents: read
  pages: write
  id-token: write

concurrency:
  group: "pages"
  cancel-in-progress: true

jobs:
  build:
    runs-on: ubuntu-latest
    
    defaults:
      run:
        working-directory: docs
    
    steps:
      - name: Checkout
        uses: actions/checkout@v4
        with:
          # 确保 CNAME 文件被检出
          fetch-depth: 0
          
      - name: Setup Ruby
        uses: ruby/setup-ruby@v1
        with:
          ruby-version: '3.3'
          bundler-cache: true
          cache-version: 0
          
      - name: Setup Pages
        id: pages
        uses: actions/configure-pages@v3
        
      - name: Build with Jekyll
        run: |
          # 构建时使用自定义域名配置
          bundle exec jekyll build
        env:
          JEKYLL_ENV: production
          # 确保使用正确的 URL
          JEKYLL_ENV_PRODUCTION: true
          
      - name: Verify _site contents
        run: |
          ls -la _site/
          # 检查 CNAME 文件是否在构建输出中
          if [ -f _site/CNAME ]; then
            echo "CNAME file found in build output"
            cat _site/CNAME
          else
            echo "CNAME file NOT found in build output"
          fi
          
      - name: Upload artifact
        uses: actions/upload-pages-artifact@v2
        with:
          path: docs/_site/

  deploy:
    environment:
      name: github-pages
      url: ${{ steps.deployment.outputs.page_url }}
    runs-on: ubuntu-latest
    needs: build
    steps:
      - name: Deploy to GitHub Pages
        id: deployment
        uses: actions/deploy-pages@v2